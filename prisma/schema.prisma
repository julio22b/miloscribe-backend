generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Doctor {
  id Int @id @default(autoincrement())
  name String 
  username String @unique 
  password String
  specialty String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}
